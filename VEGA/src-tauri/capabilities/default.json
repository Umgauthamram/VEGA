{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "cmd": "cmd",
          "args": true
        },
        {
          "cmd": "powershell",
          "args": true
        }
      ]
    },
    "notification:default",
    "global-shortcut:default",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    "dialog:default",
    "http:default"
  ]
}